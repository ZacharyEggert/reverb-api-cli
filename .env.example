# Reverb API key — obtain from https://reverb.com/my/api_settings
REVERB_API_KEY=

# Override config directory (default: ~/.config/revcli)
# REVERB_CLI_CONFIG_DIR=

# Log level for stderr output (e.g. revcli=debug). Off by default.
# REVERB_CLI_LOG=

# Directory for JSON-line log files with daily rotation. Off by default.
# REVERB_CLI_LOG_FILE=
